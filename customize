#!/usr/bin/python

# Nvidia Settings
import os
os.system("lspci | grep -E 'VGA|3D' > /tmp/pull_customize")
with open("/tmp/pull_customize", "r") as r_c:
    video_card = r_c.read()

if "NVIDIA" in video_card:
    sys.exit()
else:
    with open("./config/hypr/config/environment.conf", "r") as r_e:
        config = r_e.read()
        config = config.replace(r"# === Set Video Card === #", "")
        config = config.replace(r"env = AQ_DRM_DEVICES,/dev/dri/card2", "")
    with open("./config/hypr/config/environment.conf", "w") as w_e:
        w_e.write(config)
